<Application x:Class="Fences6.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Application Colors -->
            <SolidColorBrush x:Key="PrimaryBrush" Color="#2D7DD2"/>
            <SolidColorBrush x:Key="SecondaryBrush" Color="#1A1A2E"/>
            <SolidColorBrush x:Key="AccentBrush" Color="#45B7D1"/>
            <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F5F5"/>
            <SolidColorBrush x:Key="TextBrush" Color="#333333"/>
            <SolidColorBrush x:Key="BorderBrush" Color="#DDDDDD"/>
            
            <!-- Fence Styles -->
            <SolidColorBrush x:Key="FenceBackgroundBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="FenceBorderBrush" Color="#E0E0E0"/>
            <SolidColorBrush x:Key="FenceTitleBrush" Color="#2D7DD2"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
