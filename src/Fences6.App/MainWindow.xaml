<Window x:Class="Fences6.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:vm="clr-namespace:Fences6.App.ViewModels"
        xmlns:views="clr-namespace:Fences6.App.Views"
        mc:Ignorable="d"
        Title="Fences 6"
        Height="700" Width="1100"
        MinHeight="450" MinWidth="700"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">
    
    <Window.Resources>
        <!-- 托盘右键菜单 -->
        <ContextMenu x:Key="TrayContextMenu">
            <MenuItem Header="显示主界面" Command="{Binding ShowMainWindowCommand}"/>
            <Separator/>
            <MenuItem Header="新建桌面分组" Command="{Binding CreateNewFenceCommand}"/>
            <MenuItem Header="自动排列" Command="{Binding AutoArrangeCommand}"/>
            <MenuItem Header="刷新图标" Command="{Binding RefreshIconsCommand}"/>
            <Separator/>
            <MenuItem Header="设置" Command="{Binding OpenSettingsCommand}"/>
            <Separator/>
            <MenuItem Header="退出" Command="{Binding ExitCommand}"/>
        </ContextMenu>
        
        <!-- Fence View 数据模板 -->
        <DataTemplate x:Key="FenceViewTemplate" DataType="{x:Type vm:FenceViewModel}">
            <views:FenceView DataContext="{Binding}"/>
        </DataTemplate>
        
        <!-- 侧边栏分组项模板 -->
        <DataTemplate x:Key="SidebarFenceItemTemplate" DataType="{x:Type vm:FenceViewModel}">
            <Border x:Name="ItemBorder"
                    Background="Transparent"
                    CornerRadius="6"
                    Padding="12,8"
                    Margin="0,2"
                    Cursor="Hand"
                    MouseLeftButtonDown="SidebarItem_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 分组颜色指示器 -->
                    <Border Grid.Column="0" 
                            Width="4" Height="24" 
                            CornerRadius="2"
                            Background="{StaticResource PrimaryBrush}"
                            Margin="0,0,10,0"/>
                    
                    <!-- 分组信息 -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" 
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding IconCount, StringFormat={}{0} 个图标}" 
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                    
                    <!-- 锁定指示器 -->
                    <TextBlock Grid.Column="2" 
                               Text="🔒" 
                               FontSize="12"
                               VerticalAlignment="Center"
                               Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="ItemBorder" Property="Background" Value="#E8E8E8"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter TargetName="ItemBorder" Property="Background" Value="#2D7DD2"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>
    
    <!-- 托盘图标 -->
    <Window.Resources>
        <tb:TaskbarIcon x:Key="NotifyIcon"
                        IconSource="/Resources/app.ico"
                        ToolTipText="Fences 6 - 桌面整理工具"
                        ContextMenu="{StaticResource TrayContextMenu}"
                        TrayLeftMouseDown="NotifyIcon_TrayLeftMouseDown"/>
    </Window.Resources>
    
    <!-- 主窗口边框 -->
    <Border x:Name="MainBorder"
            Background="{StaticResource BackgroundBrush}" 
            BorderBrush="{StaticResource BorderBrush}" 
            BorderThickness="1" 
            CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="3" Opacity="0.25"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- ==================== 标题栏 ==================== -->
            <Border Grid.Row="0" 
                    Background="{StaticResource SecondaryBrush}" 
                    CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    MouseLeftButtonUp="TitleBar_MouseLeftButtonUp"
                    MouseMove="TitleBar_MouseMove">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Logo 和标题 -->
                    <StackPanel Grid.Column="0" 
                                Orientation="Horizontal" 
                                Margin="14,0"
                                VerticalAlignment="Center">
                        <Image Source="/Resources/app.ico" 
                               Width="20" Height="20" 
                               VerticalAlignment="Center"/>
                        <TextBlock Text="Fences 6" 
                                   Foreground="White" 
                                   FontSize="14" 
                                   FontWeight="SemiBold" 
                                   VerticalAlignment="Center" 
                                   Margin="10,0,0,0"/>
                    </StackPanel>
                    
                    <!-- 搜索框 -->
                    <Border Grid.Column="1" 
                            Background="#3E3E42" 
                            CornerRadius="4" 
                            Margin="20,6"
                            MaxWidth="300"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔍" 
                                       FontSize="12"
                                       Foreground="#808080"
                                       VerticalAlignment="Center"
                                       Margin="10,0,6,0"/>
                            <TextBox Grid.Column="1"
                                     x:Name="SearchBox"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="White"
                                     FontSize="12"
                                     VerticalAlignment="Center"
                                     Padding="0,8,10,8"/>
                        </Grid>
                    </Border>
                    
                    <!-- 窗口控制按钮 -->
                    <StackPanel Grid.Column="2" 
                                Orientation="Horizontal" 
                                Margin="0,4,8,4"
                                VerticalAlignment="Center">
                        <!-- 最小化 -->
                        <Button Content="&#xE921;" 
                                FontFamily="Segoe MDL2 Assets" 
                                FontSize="10"
                                Style="{StaticResource WindowButtonStyle}"
                                Click="MinimizeButton_Click"
                                ToolTip="最小化"/>
                        <!-- 最大化/还原 -->
                        <Button x:Name="MaximizeButton" 
                                Content="&#xE922;" 
                                FontFamily="Segoe MDL2 Assets" 
                                FontSize="10"
                                Style="{StaticResource WindowButtonStyle}"
                                Click="MaximizeButton_Click"
                                ToolTip="最大化"/>
                        <!-- 关闭 -->
                        <Button Content="&#xE8BB;" 
                                FontFamily="Segoe MDL2 Assets" 
                                FontSize="10"
                                Style="{StaticResource CloseButtonStyle}"
                                Click="CloseButton_Click"
                                ToolTip="关闭"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- ==================== 主内容区域 ==================== -->
            <Grid Grid.Row="1" Margin="12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- ==================== 左侧边栏 ==================== -->
                <Border Grid.Column="0" 
                        Background="{StaticResource CardBackgroundBrush}" 
                        CornerRadius="8"
                        BorderBrush="{StaticResource BorderLightBrush}"
                        BorderThickness="1"
                        Margin="0,0,8,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- 侧边栏头部 -->
                        <Border Grid.Row="0" 
                                Background="#F8F8F8" 
                                CornerRadius="8,8,0,0"
                                Padding="12,10"
                                BorderBrush="{StaticResource BorderLightBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="桌面分组" 
                                           FontSize="13" 
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Content="+"
                                        FontSize="18"
                                        FontWeight="Bold"
                                        Width="28" Height="28"
                                        Background="{StaticResource PrimaryBrush}"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Command="{Binding CreateNewFenceCommand}"
                                        ToolTip="新建分组"
                                        Style="{StaticResource PrimaryButtonStyle}"/>
                            </Grid>
                        </Border>
                        
                        <!-- 分组列表 -->
                        <ListBox x:Name="FenceList" 
                                 Grid.Row="1"
                                 ItemsSource="{Binding FenceGroups}"
                                 SelectedItem="{Binding SelectedFence}"
                                 ItemTemplate="{StaticResource SidebarFenceItemTemplate}"
                                 Style="{StaticResource SidebarListBoxStyle}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 Padding="6,4">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                        
                        <!-- 侧边栏统计 -->
                        <Border Grid.Row="2" 
                                Background="#F8F8F8" 
                                CornerRadius="0,0,8,8"
                                Padding="12,10"
                                BorderBrush="{StaticResource BorderLightBrush}"
                                BorderThickness="0,1,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="共 " 
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding FenceCount}" 
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"/>
                                <TextBlock Text=" 个分组， " 
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding TotalIconCount}" 
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"/>
                                <TextBlock Text=" 个图标" 
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
                
                <!-- ==================== 桌面画布区域 ==================== -->
                <Border Grid.Column="1" 
                        Background="{StaticResource DarkBackgroundBrush}" 
                        CornerRadius="8"
                        Margin="8,0,0,0">
                    <Grid>
                        <!-- Fence 分组画布 -->
                        <Canvas x:Name="DesktopCanvas"
                                Background="Transparent"
                                ClipToBounds="True"
                                AllowDrop="True"
                                Drop="DesktopCanvas_Drop"
                                DragOver="DesktopCanvas_DragOver">
                            <!-- FenceView 将动态添加到此处 -->
                        </Canvas>
                        
                        <!-- 空状态提示 -->
                        <StackPanel x:Name="EmptyStatePanel"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed">
                            <TextBlock Text="🗂️" 
                                       FontSize="48"
                                       HorizontalAlignment="Center"
                                       Opacity="0.3"/>
                            <TextBlock Text="还没有桌面分组" 
                                       FontSize="16"
                                       Foreground="#606060"
                                       HorizontalAlignment="Center"
                                       Margin="0,16,0,8"/>
                            <TextBlock Text="点击左上角的 + 按钮创建第一个分组" 
                                       FontSize="13"
                                       Foreground="#808080"
                                       HorizontalAlignment="Center"/>
                            <Button Content="+ 创建分组"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding CreateNewFenceCommand}"
                                    Margin="0,20,0,0"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                        
                        <!-- 加载指示器 -->
                        <Border x:Name="LoadingOverlay"
                                Background="#80000000"
                                CornerRadius="8"
                                Visibility="Collapsed">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ProgressBar IsIndeterminate="True" 
                                             Width="200" 
                                             Height="4"/>
                                <TextBlock Text="加载中..." 
                                           Foreground="White"
                                           FontSize="13"
                                           HorizontalAlignment="Center"
                                           Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
            
            <!-- ==================== 状态栏 ==================== -->
            <Border Grid.Row="2" 
                    Background="{StaticResource CardBackgroundBrush}" 
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="12,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 状态消息 -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="●" 
                                   Foreground="{StaticResource SuccessBrush}"
                                   FontSize="10"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding StatusMessage}" 
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                    
                    <!-- 快捷操作按钮 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="🔄 刷新"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding RefreshIconsCommand}"
                                Padding="10,4"
                                FontSize="11"
                                Margin="0,0,8,0"/>
                        <Button Content="⚙️ 设置"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding OpenSettingsCommand}"
                                Padding="10,4"
                                FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
